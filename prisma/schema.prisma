generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model CorsairIntegration {
  id        String           @id
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  name      String
  config    Json             @default("{}")
  dek       String?
  accounts  CorsairAccount[]

  @@map("corsair_integrations")
}

model CorsairAccount {
  id            String             @id
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenantId      String             @map("tenant_id")
  integrationId String             @map("integration_id")
  config        Json               @default("{}")
  dek           String?
  integration   CorsairIntegration @relation(fields: [integrationId], references: [id])
  entities      CorsairEntity[]
  events        CorsairEvent[]

  @@map("corsair_accounts")
}

model CorsairEntity {
  id         String         @id
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  accountId  String         @map("account_id")
  entityId   String         @map("entity_id")
  entityType String         @map("entity_type")
  version    String
  data       Json           @default("{}")
  account    CorsairAccount @relation(fields: [accountId], references: [id])

  @@map("corsair_entities")
}

model CorsairEvent {
  id        String         @id
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  accountId String         @map("account_id")
  eventType String         @map("event_type")
  payload   Json           @default("{}")
  status    String?
  account   CorsairAccount @relation(fields: [accountId], references: [id])

  @@map("corsair_events")
}

model Email {
  id              String          @id
  gmailId         String          @unique
  userId          String
  threadId        String
  from            String
  fromName        String?
  toText          String
  ccText          String?
  subject         String
  body            String
  bodyHtml        String?
  snippet         String?
  timestamp       DateTime
  read            Boolean         @default(false)
  starred         Boolean         @default(false)
  hasAttachment   Boolean         @default(false)
  labels          String[]        @default([])
  priority        String?
  category        String?
  aiClassified    Boolean         @default(false)
  aiReason        String?
  aiAction        String?
  replyGenerated  Boolean         @default(false)
  needsReply      Boolean?
  generatedReply  String?         @db.Text
  replyMode       String?
  summary         String?         @db.Text
  isSent            Boolean         @default(false)
  followUpEligibleAt DateTime?
  followUpCheckedAt  DateTime?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  emailEmbeddings EmailEmbedding?
  followUp        FollowUp?

  @@index([userId, priority])
  @@index([userId, threadId])
  @@index([userId, timestamp])
  @@index([userId, replyGenerated])
  @@index([followUpEligibleAt])
  @@map("emails")
}

model EmailEmbedding {
  id        String                @id
  emailId   String                @unique
  embedding Unsupported("vector")
  email     Email                 @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("email_embeddings")
}

model FollowUp {
  id              String    @id @default(uuid())
  userId          String
  emailId         String          @unique
  gmailId         String
  threadId        String
  subject         String
  toEmail         String
  toName          String?
  sentAt          DateTime
  status          String    @default("pending")
  lastCheckedAt   DateTime?
  replyReceivedAt DateTime?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  email           Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, sentAt])
  @@map("follow_ups")
}

model Contact {
  id                    String    @id
  userId                String
  email                 String
  name                  String?
  emailCount            Int       @default(0)
  meetingCount          Int       @default(0)
  lastInteraction       DateTime?
  lastTopic             String?
  responsePattern       String?
  preferredMeetingTimes String[]  @default([])
  relationshipStrength  Float     @default(0)
  vip                   Boolean   @default(false)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, email])
  @@map("contacts")
}

model SyncState {
  id               String   @id @default(uuid())
  userId           String   @unique
  phase            String   @default("idle")
  isInitialSync    Boolean  @default(false)
  syncStartedAt    DateTime?
  syncCompletedAt  DateTime?
  totalEmails      Int      @default(0)
  syncedEmails     Int      @default(0)
  classifiedEmails Int      @default(0)
  totalToClassify  Int      @default(0)
  lastSyncAt       DateTime?
  lastError        String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("sync_states")
}

model DailyBrief {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @db.Date
  summary      String   @db.Text
  emailCount   Int      @default(0)
  meetingCount Int      @default(0)
  followUpCount Int     @default(0)
  overdueCount Int      @default(0)
  rawInput     Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_briefs")
}

model UserAction {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  target     String
  sender     String?
  subject    String?
  category   String?
  threadId   String?
  contactId  String?
  duration   Int?     // duration in ms for AI interactions
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, actionType])
  @@index([userId, actionType, target])
  @@index([userId, createdAt])
  @@map("user_actions")
}

model WorkflowSequence {
  id          String   @id @default(uuid())
  userId      String
  sequence    String[] // e.g. ["OPEN_EMAIL", "FORWARD_EMAIL", "ARCHIVE_EMAIL"]
  patternHash String   // hash of the sequence for fast lookup
  count       Int      @default(0)
  confidence  Float    @default(0)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, patternHash])
  @@index([userId, confidence])
  @@map("workflow_sequences")
}

model WorkflowCandidate {
  id                String   @id @default(uuid())
  userId            String
  name              String
  description       String   @db.Text
  category          String   // e.g. "email_triage", "support_escalation", "recruiting"
  confidence        Float    @default(0)
  frequency         Int      @default(0)
  consistency       Float    @default(0) // 0-1 score
  recency           Float    @default(0) // 0-1 score
  timeSavedPerWeek  Float    @default(0) // in minutes
  triggerActions    Json?    // the actions that trigger this
  suggestedActions  Json?    // the actions that should be taken
  status            String   @default("suggested") // suggested, enabled, dismissed, executed
  automationRuleId  String?  // link to automation rule if enabled
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, name])
  @@index([userId, status])
  @@index([userId, confidence])
  @@map("workflow_candidates")
}

model WorkflowPattern {
  id              String    @id @default(uuid())
  userId          String
  actionType      String
  target          String
  description     String
  count           Int       @default(0)
  status          String    @default("suggested")
  suppressedUntil DateTime?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, actionType, target])
  @@index([userId, status])
  @@map("workflow_patterns")
}

model AutomationRule {
  id             String   @id @default(uuid())
  userId         String
  name           String
  enabled        Boolean  @default(true)
  triggerType    String
  triggerValue   String
  actionType     String
  actionTarget   String
  executionCount Int      @default(0)
  lastExecutedAt DateTime?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, enabled])
  @@map("automation_rules")
}

model AutomationExecution {
  id          String   @id @default(uuid())
  ruleId      String
  emailId     String
  actionTaken String
  success     Boolean  @default(true)
  error       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([ruleId])
  @@index([emailId])
  @@map("automation_executions")
}